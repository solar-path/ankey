# Test Environment Configuration
NODE_ENV=test

# Test Database URLs - Use different databases for testing
DATABASE_URL=postgresql://user:password@localhost:5432/ankey_test_core
TENANT_DATABASE_PREFIX=ankey_test_tenant

# Test-specific settings
SESSION_SECRET=test_secret_key_for_sessions_only
ENCRYPTION_KEY=test_encryption_key_32_chars_long

# API Settings
PORT=3001
API_URL=http://localhost:3001

# Email (disabled in tests)
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Logging
LOG_LEVEL=warn

# Development flags
SKIP_AUTH=false
SKIP_RATE_LIMITING=true
SKIP_EMAIL_VERIFICATION=true
{
  "name": "ankey",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun vite\" \"bun run --watch src/api/api.ts\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "debug": "concurrently \"DEBUG=vite:* vite\" \"DEBUG=* tsx src/api/api.ts\"",
    "setup-core": "tsx scripts/setup-core-admin.ts",
    "seed": "tsx scripts/seed-database.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate:core": "drizzle-kit generate --config=drizzle.core.config.ts",
    "db:generate:tenant": "drizzle-kit generate --config=drizzle.tenant.config.ts",
    "db:migrate:core": "drizzle-kit push --config=drizzle.core.config.ts",
    "db:migrate:tenant": "drizzle-kit push --config=drizzle.tenant.config.ts",
    "db:migrate:tenant:all": "tsx scripts/migrate-all-tenants.ts",
    "db:studio:core": "drizzle-kit studio --config=drizzle.core.config.ts",
    "db:studio:tenant": "drizzle-kit studio --config=drizzle.tenant.config.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.2",
    "@hookform/resolvers": "^5.2.1",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-router": "^1.130.12",
    "@tanstack/react-router-devtools": "^1.130.13",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.4",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.8.12",
    "lucia": "^3.2.2",
    "lucide-react": "^0.536.0",
    "nodemailer": "^7.0.5",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "react": "^19.1.1",
    "react-day-picker": "^9.8.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "zod": "^4.0.15",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tanstack/router-plugin": "^1.130.15",
    "@types/bun": "^1.2.19",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.3.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.0"
  }
}
